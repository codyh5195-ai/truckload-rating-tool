# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# URL of your deployed frontend (used for CORS in production)
FRONTEND_URL=https://your-frontend-domain.com

# ── DAT RateView API ──────────────────────────────────────────────────────────
# Set USE_MOCK=true during development if you don't have DAT credentials yet.
# Flip to false and add your credentials when going live.
DAT_USE_MOCK=true

DAT_CLIENT_ID=your_dat_client_id
DAT_CLIENT_SECRET=your_dat_client_secret

# Override only if DAT changes their endpoint URLs
# DAT_TOKEN_URL=https://identity.dat.com/access/oauth/token
# DAT_API_BASE_URL=https://api.dat.com/rate-view/v3
